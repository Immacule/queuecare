{
  "name": "queuecare",
  "version": "1.0.0",
  "description": "Clinic appointment & queue management system",
  "main": "src/app.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "test": "cross-env NODE_ENV=test jest --runInBand --forceExit",
    "test:api": "cross-env NODE_ENV=test jest tests/api --runInBand --forceExit",
    "test:ui": "playwright test tests/ui",
    "test:coverage": "cross-env NODE_ENV=test jest --coverage --runInBand --forceExit",
    "seed": "node scripts/seed.js"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.0",
    "mongodb": "^7.2.0",
    "mongoose": "^8.4.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.40.0",
    "cross-env": "^7.0.3",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "supertest": "^6.3.3"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/api/**/*.test.js"
    ],
    "testTimeout": 60000,
    "collectCoverageFrom": [
      "src/**/*.js"
    ]
  }
}